          "id": "pre-algebra-fractions-addition",
          "name": "Addition",
          "latex": "\\frac{a}{b}+\\frac{c}{d}=\\frac{ad+bc}{bd}"
        },
        {
          "id": "pre-algebra-fractions-subtraction",
          "name": "Subtraction",
          "latex": "\\frac{a}{b}-\\frac{c}{d}=\\frac{ad-bc}{bd}"
        },
        {
          "id": "pre-algebra-fractions-multiplication",
          "name": "Multiplication",
          "latex": "\\frac{a}{b}\\cdot\\frac{c}{d}=\\frac{ac}{bd}"
        },
        {
          "id": "pre-algebra-fractions-division",
          "name": "Division",
          "latex": "\\frac{a}{b}\\div\\frac{c}{d}=\\frac{a}{b}\\cdot\\frac{d}{c}=\\frac{ad}{bc}"
        }
      ]
    },
