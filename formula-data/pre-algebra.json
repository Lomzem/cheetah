{
  "id": "pre-algebra",
  "name": "PRE-ALGEBRA",
  "categories": [
    {
      "id": "order-of-operations-pemdas",
      "name": "Order of Operations (PEMDAS)",
      "formulas": [
        {
          "id": "pre-algebra-order-of-operations-pemdas-pemdas-definition",
          "name": "PEMDAS Definition",
          "typst": "\"Parentheses\" -> \"Exponents\" -> \"Multiply/Divide\" -> \"Add/Subtract\""
        }
      ]
    },
    {
      "id": "fractions",
      "name": "Fractions",
      "formulas": [
        {
          "id": "pre-algebra-fractions-addition",
          "name": "Addition",
          "typst": "(a) / (b)+(c) / (d)=(a d+b c) / (b d)"
        },
        {
          "id": "pre-algebra-fractions-subtraction",
          "name": "Subtraction",
          "typst": "(a) / (b)-(c) / (d)=(a d-b c) / (b d)"
        },
        {
          "id": "pre-algebra-fractions-multiplication",
          "name": "Multiplication",
          "typst": "(a) / (b) dot (c) / (d)=(a c) / (b d)"
        },
        {
          "id": "pre-algebra-fractions-division",
          "name": "Division",
          "typst": "(a) / (b) div (c) / (d)=(a) / (b) dot (d) / (c)=(a d) / (b c)"
        }
      ]
    },
    {
      "id": "ratios-and-proportions",
      "name": "Ratios and Proportions",
      "formulas": [
        {
          "id": "pre-algebra-ratios-and-proportions-proportion",
          "name": "Proportion",
          "typst": "(a) / (b)=(c) / (d) => a d=b c"
        },
        {
          "id": "pre-algebra-ratios-and-proportions-unit-rate",
          "name": "Unit Rate",
          "typst": "\"Unit Rate\"=(\"Total\") / (\"Number of Units\")"
        }
      ]
    },
    {
      "id": "properties-of-numbers",
      "name": "Properties of Numbers",
      "formulas": [
        {
          "id": "pre-algebra-properties-of-numbers-commutative",
          "name": "Commutative",
          "typst": "a+b=b+a"
        },
        {
          "id": "pre-algebra-properties-of-numbers-associative",
          "name": "Associative",
          "typst": "(a+b)+c=a+(b+c)"
        },
        {
          "id": "pre-algebra-properties-of-numbers-distributive",
          "name": "Distributive",
          "typst": "a(b+c)=a b+a c"
        },
        {
          "id": "pre-algebra-properties-of-numbers-identity",
          "name": "Identity",
          "typst": "a+0=a"
        },
        {
          "id": "pre-algebra-properties-of-numbers-inverse",
          "name": "Inverse",
          "typst": "a+(-a)=0"
        }
      ]
    },
    {
      "id": "area-and-perimeter",
      "name": "Area and Perimeter",
      "formulas": [
        {
          "id": "pre-algebra-area-and-perimeter-rectangle-area-perimeter",
          "name": "Rectangle Area/Perimeter",
          "typst": "A_\"rect\"=l w ; ; P_\"rect\"=2l+2w"
        },
        {
          "id": "pre-algebra-area-and-perimeter-triangle-area",
          "name": "Triangle Area",
          "typst": "A_\"tri\"=(1) / (2)b h"
        },
        {
          "id": "pre-algebra-area-and-perimeter-circle-area-circumference",
          "name": "Circle Area/Circumference",
          "typst": "A_\"circle\"= pi r^2 ; ; C=2 pi r"
        },
        {
          "id": "pre-algebra-area-and-perimeter-rectangular-prism-volume",
          "name": "Rectangular Prism Volume",
          "typst": "V_\"rect prism\"=l w h"
        }
      ]
    },
    {
      "id": "solving-equations",
      "name": "Solving Equations",
      "formulas": [
        {
          "id": "pre-algebra-solving-equations-linear-solution",
          "name": "Linear Solution",
          "typst": "a x+b=c => x=(c-b) / (a)"
        },
        {
          "id": "pre-algebra-solving-equations-absolute-value",
          "name": "Absolute Value",
          "typst": "|x|=a => x=a \"or\" x=-a"
        },
        {
          "id": "pre-algebra-solving-equations-transitive-property",
          "name": "Transitive Property",
          "typst": "\"If\" a=b \"and\" b=c, \"then\" a=c"
        }
      ]
    }
  ]
}
