      "name": "Exponents",
      "formulas": [
        {
          "id": "algebra-i-exponents-product-rule",
          "name": "Product Rule",
          "latex": "a^m a^n = a^{m+n}"
        },
        {
          "id": "algebra-i-exponents-quotient-rule",
          "name": "Quotient Rule",
          "latex": "\\frac{a^m}{a^n}=a^{m-n}"
        },
        {
          "id": "algebra-i-exponents-power-rule",
          "name": "Power Rule",
          "latex": "(a^m)^n=a^{mn}"
        },
        {
          "id": "algebra-i-exponents-negative-exponent",
          "name": "Negative Exponent",
          "latex": "a^{-n}=\\frac{1}{a^n}"
        },
        {
          "id": "algebra-i-exponents-zero-exponent",
          "name": "Zero Exponent",
          "latex": "a^0=1"
        },
        {
          "id": "algebra-i-exponents-radical-to-exponent",
          "name": "Radical to Exponent",
          "latex": "\\sqrt[n]{a^m}=a^{m/n}"
        }
      ]
    },
    {
