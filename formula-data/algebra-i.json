          "typst": "f(x)=y"
        },
        {
          "id": "algebra-i-functions-domain",
          "name": "Domain",
          "typst": "\"Domain: all valid input\" x \"values\""
        },
        {
          "id": "algebra-i-functions-range",
          "name": "Range",
          "typst": "\"Range: all output\" y \"values\""
        },
        {
          "id": "algebra-i-functions-vertical-line-test",
