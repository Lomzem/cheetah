  "categories": [
    {
      "id": "linear-equations",
      "name": "Linear Equations",
      "formulas": [
        {
          "id": "algebra-i-linear-equations-slope-formula",
          "name": "Slope Formula",
          "typst": "m=(y_2-y_1) / (x_2-x_1)"
        },
        {
          "id": "algebra-i-linear-equations-point-slope-form",
          "name": "Point-Slope Form",
          "typst": "y-y_1=m(x-x_1)"
        },
        {
          "id": "algebra-i-linear-equations-slope-intercept-form",
          "name": "Slope-Intercept Form",
          "typst": "y=m x+b"
        },
        {
          "id": "algebra-i-linear-equations-standard-form",
          "name": "Standard Form",
          "typst": "A x+B y=C"
        }
      ]
    },
    {
      "id": "inequalities",
      "name": "Inequalities",
      "formulas": [
        {
          "id": "algebra-i-inequalities-multiply-by-positive",
          "name": "Multiply by Positive",
          "typst": "\"If\" a>b \"and\" c>0, \"then\" a c>b c"
        },
        {
          "id": "algebra-i-inequalities-multiply-by-negative",
          "name": "Multiply by Negative",
          "typst": "\"If\" a>b \"and\" c<0, \"then\" a c<b c"
        },
        {
          "id": "algebra-i-inequalities-absolute-less-than",
          "name": "Absolute Less Than",
          "typst": "|x|<a => -a<x<a"
        },
        {
          "id": "algebra-i-inequalities-absolute-greater-than",
          "name": "Absolute Greater Than",
          "typst": "|x|>a => x>a \"or\" x<-a"
        }
      ]
    },
    {
      "id": "integer-rules",
      "name": "Integer Rules",
      "formulas": [
        {
          "id": "algebra-i-integer-rules-positive-x-positive",
          "name": "Positive x Positive",
          "typst": "(+)(+)=+"
        },
        {
          "id": "algebra-i-integer-rules-negative-x-negative",
          "name": "Negative x Negative",
          "typst": "(-)(-)=+"
        },
        {
          "id": "algebra-i-integer-rules-positive-x-negative",
          "name": "Positive x Negative",
          "typst": "(+)(-)=-"
        },
        {
          "id": "algebra-i-integer-rules-negative-x-positive",
          "name": "Negative x Positive",
          "typst": "(-)(+)=-"
        },
        {
          "id": "algebra-i-integer-rules-subtracting-negatives",
          "name": "Subtracting Negatives",
          "typst": "a-(-b)=a+b"
        }
      ]
    },
    {
      "id": "decimals-and-percents",
      "name": "Decimals and Percents",
      "formulas": [
        {
          "id": "algebra-i-decimals-and-percents-percent-formula",
          "name": "Percent Formula",
          "typst": "\"Percent\"=(\"Part\") / (\"Whole\") times 100"
        },
        {
          "id": "algebra-i-decimals-and-percents-part-formula",
          "name": "Part Formula",
          "typst": "\"Part\"=\"Whole\" times (\"Percent\") / (100)"
        },
        {
          "id": "algebra-i-decimals-and-percents-decimal-to-percent",
          "name": "Decimal to Percent",
          "typst": "\"Decimal to Percent: move decimal 2 places right\""
        },
        {
          "id": "algebra-i-decimals-and-percents-percent-to-decimal",
          "name": "Percent to Decimal",
          "typst": "\"Percent to Decimal: move decimal 2 places left\""
        }
      ]
    },
    {
      "id": "mean-median-mode",
      "name": "Mean, Median, Mode",
      "formulas": [
        {
          "id": "algebra-i-mean-median-mode-mean",
          "name": "Mean",
          "typst": "\"Mean\"=(\"Sum of values\") / (\"Number of values\")"
        },
        {
          "id": "algebra-i-mean-median-mode-median",
          "name": "Median",
          "typst": "\"Median: middle value when sorted\""
        },
        {
          "id": "algebra-i-mean-median-mode-mode",
          "name": "Mode",
          "typst": "\"Mode: most frequently occurring value\""
        }
      ]
    },
    {
      "id": "quadratic-equations",
      "name": "Quadratic Equations",
      "formulas": [
        {
          "id": "algebra-i-quadratic-equations-standard-form",
          "name": "Standard Form",
          "typst": "a x^2+b x+c=0"
        },
        {
          "id": "algebra-i-quadratic-equations-quadratic-formula",
          "name": "Quadratic Formula",
          "typst": "x = (-b p l u s.m i n u s sqrt(b^2 - 4 a c)) / (2 a)"
        },
        {
          "id": "algebra-i-quadratic-equations-vertex-form",
          "name": "Vertex Form",
          "typst": "y=a(x-h)^2+k"
        },
        {
          "id": "algebra-i-quadratic-equations-axis-of-symmetry",
          "name": "Axis of Symmetry",
          "typst": "x=-(b) / (2a)"
        }
      ]
    },
    {
      "id": "polynomials",
      "name": "Polynomials",
      "formulas": [
        {
          "id": "algebra-i-polynomials-perfect-square-addition",
          "name": "Perfect Square (Addition)",
          "typst": "(a+b)^2=a^2+2a b+b^2"
        },
        {
          "id": "algebra-i-polynomials-perfect-square-subtraction",
          "name": "Perfect Square (Subtraction)",
          "typst": "(a-b)^2=a^2-2a b+b^2"
        },
        {
          "id": "algebra-i-polynomials-difference-of-squares",
          "name": "Difference of Squares",
          "typst": "a^2-b^2=(a-b)(a+b)"
        },
        {
          "id": "algebra-i-polynomials-foil",
          "name": "FOIL",
          "typst": "(a+b)(c+d)=a c+a d+b c+b d"
        }
      ]
    },
    {
      "id": "exponents",
      "name": "Exponents",
      "formulas": [
        {
          "id": "algebra-i-exponents-product-rule",
          "name": "Product Rule",
          "typst": "a^m a^n = a^m+n"
        },
        {
          "id": "algebra-i-exponents-quotient-rule",
          "name": "Quotient Rule",
          "typst": "(a^m) / (a^n)=a^m-n"
        },
        {
          "id": "algebra-i-exponents-power-rule",
          "name": "Power Rule",
          "typst": "(a^m)^n=a^m n"
        },
        {
          "id": "algebra-i-exponents-negative-exponent",
          "name": "Negative Exponent",
          "typst": "a^-n=(1) / (a^n)"
        },
        {
          "id": "algebra-i-exponents-zero-exponent",
          "name": "Zero Exponent",
          "typst": "a^0=1"
        },
        {
          "id": "algebra-i-exponents-radical-to-exponent",
          "name": "Radical to Exponent",
          "typst": "root(n, a^m)=a^m/n"
        }
      ]
    },
    {
      "id": "radicals",
      "name": "Radicals",
      "formulas": [
        {
          "id": "algebra-i-radicals-product-rule",
          "name": "Product Rule",
          "typst": "sqrt(a b)=sqrt(a) dot sqrt(b)"
        },
        {
          "id": "algebra-i-radicals-quotient-rule",
          "name": "Quotient Rule",
          "typst": "sqrt((a) / (b))=(sqrt(a)) / (sqrt(b))"
        },
        {
          "id": "algebra-i-radicals-like-radicals",
          "name": "Like Radicals",
          "typst": "a s q r t(b)+c s q r t(b)=(a+c)sqrt(b)"
        },
        {
          "id": "algebra-i-radicals-square-of-square-root",
          "name": "Square of Square Root",
          "typst": "(sqrt(a))^2=a"
        }
      ]
    },
    {
      "id": "functions",
      "name": "Functions",
      "formulas": [
        {
