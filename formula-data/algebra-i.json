        {
          "id": "algebra-i-polynomials-difference-of-squares",
          "name": "Difference of Squares",
          "latex": "a^2-b^2=(a-b)(a+b)"
        },
        {
          "id": "algebra-i-polynomials-foil",
          "name": "FOIL",
          "latex": "(a+b)(c+d)=ac+ad+bc+bd"
        }
      ]
    },
    {
