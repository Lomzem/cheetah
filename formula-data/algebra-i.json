      "formulas": [
        {
          "id": "algebra-i-absolute-value-definition",
          "name": "Definition",
          "latex": "|a| =\\begin{cases} a & a \\ge 0 \\\\ -a & a < 0 \\end{cases}"
        },
        {
          "id": "algebra-i-absolute-value-product",
          "name": "Product",
          "latex": "|a \\cdot b| = |a||b|"
        },
        {
          "id": "algebra-i-absolute-value-quotient",
          "name": "Quotient",
          "latex": "\\left|\\frac{a}{b}\\right| = \\frac{|a|}{|b|}"
        },
        {
          "id": "algebra-i-absolute-value-triangle-inequality",
          "name": "Triangle Inequality",
          "latex": "|a+b| \\le |a| + |b|"
        }
      ]
    },
    {
      "id": "rational-expressions",
      "name": "Rational Expressions",
      "formulas": [
        {
          "id": "algebra-i-rational-expressions-multiplication",
          "name": "Multiplication",
          "latex": "\\left(\\frac{a}{b}\\right)\\left(\\frac{c}{d}\\right)=\\frac{ac}{bd}"
        },
        {
          "id": "algebra-i-rational-expressions-division",
          "name": "Division",
          "latex": "\\left(\\frac{a}{b}\\right)\\div\\left(\\frac{c}{d}\\right)=\\left(\\frac{a}{b}\\right)\\left(\\frac{d}{c}\\right)=\\frac{ad}{bc}"
        }
      ]
    }
  ]
