          "typst": "\"Vertical Line Test: each\" x -> \"one\" y"
        }
      ]
    },
    {
      "id": "absolute-value",
      "name": "Absolute Value",
      "formulas": [
        {
          "id": "algebra-i-absolute-value-definition",
          "name": "Definition",
          "typst": "abs(a) = cases(a & a >= 0, -a & a < 0)"
        },
        {
          "id": "algebra-i-absolute-value-product",
          "name": "Product",
          "typst": "|a dot b| = |a||b|"
        },
        {
          "id": "algebra-i-absolute-value-quotient",
          "name": "Quotient",
          "typst": "abs((a) / (b)) = abs(a) / abs(b)"
        },
        {
          "id": "algebra-i-absolute-value-triangle-inequality",
          "name": "Triangle Inequality",
          "typst": "|a+b| <= |a| + |b|"
        }
      ]
    },
    {
      "id": "rational-expressions",
      "name": "Rational Expressions",
      "formulas": [
        {
          "id": "algebra-i-rational-expressions-multiplication",
          "name": "Multiplication",
          "typst": "((a) / (b)) * ((c) / (d)) = (a c) / (b d)"
        },
        {
          "id": "algebra-i-rational-expressions-division",
          "name": "Division",
          "typst": "((a) / (b)) div ((c) / (d)) = ((a) / (b)) * ((d) / (c)) = (a d) / (b c)"
        }
      ]
    }
  ]
}
